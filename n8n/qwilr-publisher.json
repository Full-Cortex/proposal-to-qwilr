{
  "name": "Proposal - Publish to Qwilr",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "publish-to-qwilr",
        "responseMode": "responseNode"
      },
      "id": "webhook",
      "name": "Receive Proposal",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.PROPOSAL_QWILR_API_URL || 'http://localhost:8000' }}/api/proposals/create?publish=true",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {
          "timeout": 30000,
          "retry": {
            "enabled": true,
            "maxRetries": 3,
            "retryInterval": 2000
          }
        }
      },
      "id": "create-qwilr",
      "name": "Create Qwilr Page",
      "type": "n8n-nodes-base.httpRequest",
      "position": [450, 300],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "operation": "update",
        "table": "agency_proposals",
        "columns": "qwilr_page_id,qwilr_url,qwilr_share_url,qwilr_status",
        "matchingColumns": "proposal_id",
        "fieldsToSend": {
          "values": [
            { "fieldName": "proposal_id", "fieldValue": "={{ $('Receive Proposal').first().json.proposal_id }}" },
            { "fieldName": "qwilr_page_id", "fieldValue": "={{ $json.page_id }}" },
            { "fieldName": "qwilr_url", "fieldValue": "={{ $json.url }}" },
            { "fieldName": "qwilr_share_url", "fieldValue": "={{ $json.share_url }}" },
            { "fieldName": "qwilr_status", "fieldValue": "={{ $json.status }}" }
          ]
        }
      },
      "id": "update-db",
      "name": "Update Proposal Record",
      "type": "n8n-nodes-base.supabase",
      "position": [650, 300]
    },
    {
      "parameters": {
        "channel": "#sales",
        "text": "🔗 *Proposal Published to Qwilr*\n\n*Client:* {{ $('Receive Proposal').first().json.client.company }}\n*Title:* {{ $('Receive Proposal').first().json.title }}\n*Qwilr Link:* {{ $('Create Qwilr Page').first().json.share_url }}\n\n_Send this link to the client for review and signature._"
      },
      "id": "notify-success",
      "name": "Notify Team",
      "type": "n8n-nodes-base.slack",
      "position": [850, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true, page_id: $('Create Qwilr Page').first().json.page_id, url: $('Create Qwilr Page').first().json.url, share_url: $('Create Qwilr Page').first().json.share_url }) }}"
      },
      "id": "respond-success",
      "name": "Return Result",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1050, 300]
    },
    {
      "parameters": {
        "channel": "#sales",
        "text": "⚠️ *Qwilr Publish Failed*\n\n*Client:* {{ $('Receive Proposal').first().json.client.company }}\n*Title:* {{ $('Receive Proposal').first().json.title }}\n*Proposal ID:* {{ $('Receive Proposal').first().json.proposal_id }}\n*Error:* {{ $json.error?.message || 'Unknown error' }}\n\n_Please retry manually or check the Qwilr service._"
      },
      "id": "notify-error",
      "name": "Notify Error",
      "type": "n8n-nodes-base.slack",
      "position": [650, 500]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: false, error: $json.error?.message || 'Qwilr page creation failed', proposal_id: $('Receive Proposal').first().json.proposal_id }) }}",
        "options": {
          "responseCode": 502
        }
      },
      "id": "respond-error",
      "name": "Return Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [850, 500]
    }
  ],
  "connections": {
    "Receive Proposal": {
      "main": [[{"node": "Create Qwilr Page", "type": "main", "index": 0}]]
    },
    "Create Qwilr Page": {
      "main": [
        [{"node": "Update Proposal Record", "type": "main", "index": 0}],
        [{"node": "Notify Error", "type": "main", "index": 0}]
      ]
    },
    "Update Proposal Record": {
      "main": [[{"node": "Notify Team", "type": "main", "index": 0}]]
    },
    "Notify Team": {
      "main": [[{"node": "Return Result", "type": "main", "index": 0}]]
    },
    "Notify Error": {
      "main": [[{"node": "Return Error", "type": "main", "index": 0}]]
    }
  }
}
